{
  "name": "ghost-qa",
  "version": "1.0.0",
  "description": "Autonomous QA bot that tests your local web apps in the background",
  "main": "src/main.js",
  "scripts": {
    "start": "npm run build && electron .",
    "dev": "concurrently \"npm run watch\" \"NODE_ENV=development electron .\"",
    "build": "esbuild src/renderer/App.jsx --bundle --outfile=src/renderer/dist/bundle.js --loader:.jsx=jsx",
    "watch": "esbuild src/renderer/App.jsx --bundle --outfile=src/renderer/dist/bundle.js --loader:.jsx=jsx --watch",
    "postinstall": "npx playwright install chromium"
  },
  "keywords": ["electron", "qa", "testing", "automation", "playwright"],
  "author": "",
  "license": "MIT",
  "devDependencies": {
    "concurrently": "^8.2.2",
    "electron": "^28.0.0",
    "esbuild": "^0.19.0"
  },
  "dependencies": {
    "playwright": "^1.40.0",
    "react": "^18.2.0",
    "react-dom": "^18.2.0"
  }
}
